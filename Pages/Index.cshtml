@page
@model IndexModel
@{ ViewData["Title"] = "PC Build Advisor"; }

<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="utf-8" />
    <title>PC Build Advisor</title>
    <style>
        body { font-family: sans-serif; max-width: 600px; margin: 60px auto; padding: 0 16px; background: #f5f5f5; }
        h1   { font-size: 1.5rem; margin-bottom: 24px; }
        label { display: block; margin-top: 16px; font-weight: bold; }
        select { width: 100%; padding: 8px; margin-top: 4px; border-radius: 4px; border: 1px solid #ccc; }
        button { margin-top: 24px; padding: 10px 28px; background: #0070f3; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 1rem; }
        button:hover { background: #005bb5; }
        .card { background: white; border-radius: 8px; padding: 20px 24px; margin-top: 32px; box-shadow: 0 2px 8px rgba(0,0,0,.1); }
        .card h2 { margin-top: 0; color: #0070f3; }
        .card table { width: 100%; border-collapse: collapse; }
        .card td { padding: 6px 0; border-bottom: 1px solid #eee; }
        .card td:first-child { font-weight: bold; width: 140px; color: #555; }
        .price { font-size: 1.2rem; font-weight: bold; color: #2a9d2a; margin-top: 12px; }
    </style>
</head>
<body>

<h1>🖥️ PC Build Advisor</h1>

<form method="post">
    <label>Scop</label>
    <select name="SelectedScop">
        @foreach (var s in Model.Scopuri)
        {
            <option value="@s.Key" selected="@(Model.SelectedScop == s.Key ? "selected" : null)">@s.Value</option>
        }
    </select>

    <label>Buget</label>
    <select name="SelectedBuget">
        @foreach (var b in Model.Bugete)
        {
            <option value="@b.Key" selected="@(Model.SelectedBuget == b.Key ? "selected" : null)">@b.Value (@b.Key.Replace("buget_",""))</option>
        }
    </select>

    <button type="submit">Recomandă configurație</button>
</form>

@if (Model.Result != null)
{
    <div class="card">
        <h2>@Model.Result.Descriere</h2>
        <table>
            <tr><td>CPU</td><td>@Model.Result.Cpu</td></tr>
            <tr><td>GPU</td><td>@Model.Result.Gpu</td></tr>
            <tr><td>RAM</td><td>@Model.Result.Ram</td></tr>
            <tr><td>Stocare</td><td>@Model.Result.Stocare</td></tr>
            <tr><td>Placă de bază</td><td>@Model.Result.Placa_De_Baza</td></tr>
            <tr><td>Sursă</td><td>@Model.Result.Sursa</td></tr>
        </table>
        <p class="price">💰 @Model.Result.Pret_Estimat</p>
    </div>
}

</body>
</html>